# Baileys Gateway Configuration
BAILEYS_URL=http://localhost:3000
BAILEYS_SESSION_ID=default
BAILEYS_WEBHOOK_PORT=3001

# Security - Comma separated phone numbers (without +)
ALLOWED_NUMBERS=628123456789,628987654321

# Claude API Configuration
CLAUDE_API_KEY=your_anthropic_api_key_here
DEFAULT_MODEL=claude-3-5-sonnet-20241022

# Session Management
SESSION_IDLE_TIMEOUT=1800000        # 30 minutes (in milliseconds)
SESSION_CLEANUP_INTERVAL=300000     # 5 minutes (in milliseconds)
MAX_CONCURRENT_SESSIONS=10
SESSION_STORAGE_PATH=./data/sessions

# Logging
LOG_LEVEL=info                      # error, warn, info, debug
LOG_FILE=./data/logs/codebridge.log
LOG_MAX_SIZE=10485760              # 10MB
LOG_MAX_FILES=5

# Application
NODE_ENV=production
PORT=3001

# Rate Limiting (optional)
RATE_LIMIT_WINDOW=60000            # 1 minute
RATE_LIMIT_MAX_REQUESTS=10         # Max 10 messages per minute per user
