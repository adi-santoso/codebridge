# CodeBridge Socket.IO Server Configuration

# Socket.IO Server
SOCKET_PORT=3848
SOCKET_AUTH_KEY=codebridge-secret-key-change-in-production
ALLOWED_ORIGINS=http://localhost:3000

# Kreova Configuration
ANTHROPIC_API_KEY=kv-10f188b357d5f639fced98fe4c6934f8dc561c25c7d98be9
ANTHROPIC_BASE_URL=http://127.0.0.1:3847/
CLAUDE_MODEL=kiro-claude-sonnet-4.5

# Session Limits
MAX_CONCURRENT_SESSIONS=50
MAX_HISTORY_LENGTH=20
REQUEST_TIMEOUT=30000

# Logging
LOG_LEVEL=info
DEBUG=false

# Rate Limiting
RATE_LIMIT_MAX_REQUESTS=10
RATE_LIMIT_WINDOW_MS=60000

# Security - WhatsApp Number Whitelist (comma-separated)
# Format: country_code + number without + or spaces (e.g., 6285727042754)
# Multiple numbers: 6285727042754,628123456789,628987654321
# Leave empty to allow ALL numbers (NOT RECOMMENDED for production)
ALLOWED_WHATSAPP_NUMBERS=6285727042754

# Command System Configuration
COMMAND_RATE_LIMIT_WINDOW=60000      # 1 minute (in milliseconds)
COMMAND_RATE_LIMIT_CALLS=20          # 20 commands per window per user
COMMAND_HISTORY_MAX=100              # Keep last 100 commands per user in DB
COMMAND_ENABLE_ADMIN=false           # Enable admin commands (Phase 9)

# File Operations (Phase 5)
FILE_OPS_MAX_SIZE=1048576            # 1MB max for /cat command
FILE_OPS_TREE_MAX_DEPTH=5            # Max depth for /tree command
FILE_OPS_SEARCH_MAX_RESULTS=50       # Max results for /search command

# Session Management (Phase 2)
SESSION_SNAPSHOT_MAX_SIZE=10485760   # 10MB max snapshot size
SESSION_MAX_SAVED=10                 # Max saved sessions per user
