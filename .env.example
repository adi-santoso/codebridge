# CodeBridge environment template
# Copy to .env and fill real values. Do not commit secrets.

# --- Gateway (CodeBridge is Socket.IO CLIENT) ---
GATEWAY_URL=https://chat.gatrion.my.id
GATEWAY_AUTH_KEY=change-me-in-production
# Optional: comma-separated gateway room/session IDs to join on boot
GATEWAY_SESSIONS=

# Legacy Socket.IO server mode (archived; not used by src/main.js)
# SOCKET_PORT=3848
# SOCKET_AUTH_KEY=codebridge-secret-key-change-in-production
# ALLOWED_ORIGINS=http://localhost:3000

# --- Claude / custom endpoint ---
# Often also set in ~/.claude/settings.json for the CLI subprocess
ANTHROPIC_API_KEY=your-api-key-here
ANTHROPIC_BASE_URL=http://127.0.0.1:3847/
CLAUDE_MODEL=your-model-id

# --- Projects & sessions ---
PROJECT_ROOT_PATH=D:/working/gatrion
# PROJECT_PATHS=
SESSION_DB_PATH=./.codebridge/sessions.db
MAX_CONCURRENT_SESSIONS=10
MAX_HISTORY_LENGTH=20
REQUEST_TIMEOUT=30000

# --- Logging ---
LOG_LEVEL=info
DEBUG=false

# --- Rate limiting ---
RATE_LIMIT_MAX_REQUESTS=10
RATE_LIMIT_WINDOW_MS=60000

# --- Security: WhatsApp whitelist ---
# country_code + number, no + or spaces. Empty = allow ALL (dev only, insecure)
ALLOWED_WHATSAPP_NUMBERS=628xxxxxxxxxx
WHITELIST_MODE=both
# env | database | both

# --- Command system ---
COMMAND_RATE_LIMIT_WINDOW=60000
COMMAND_RATE_LIMIT_CALLS=20
COMMAND_HISTORY_MAX=100
COMMAND_ENABLE_ADMIN=false

# --- File ops ---
FILE_OPS_MAX_SIZE=1048576
FILE_OPS_TREE_MAX_DEPTH=5
FILE_OPS_SEARCH_MAX_RESULTS=50
FILE_OPS_WHATSAPP_MAX_LENGTH=4000

# --- Session snapshots ---
SESSION_SNAPSHOT_MAX_SIZE=10485760
SESSION_MAX_SAVED=10
SESSION_HISTORY_DEFAULT_LIMIT=10
SESSION_HISTORY_MAX_LIMIT=50

# --- Tool control ---
TOOL_AUDIT_ENABLED=true
TOOL_AUDIT_LOG_PARAMS=true
TOOL_AUDIT_LOG_RESULTS=false
TOOL_AUDIT_MAX_ENTRIES=1000
TOOL_PERMISSION_MODE=none
TOOL_CANCEL_TIMEOUT=5000
TOOL_RETRY_MAX_ATTEMPTS=3

# --- Debug / metrics ---
DEBUG_LOG_MAX_ENTRIES=1000
DEBUG_LOG_RETENTION_HOURS=24
ERROR_HISTORY_MAX_ENTRIES=500
ERROR_HISTORY_RETENTION_DAYS=30
METRICS_INCLUDE_TOKEN_USAGE=false

# --- Response modes ---
RESPONSE_MODE_DEFAULT=balanced
RESPONSE_ALLOW_CODE_ONLY=true
RESPONSE_ALLOW_EXPLAIN_ONLY=true

# --- Context (Phase 7) ---
CONTEXT_MAX_FILES=10
CONTEXT_MAX_FILE_SIZE=102400
CONTEXT_MAX_TOTAL_SIZE=1048576
CONTEXT_PERSIST_TO_DB=true
IGNORE_DEFAULT_PATTERNS=node_modules,dist,.git

# --- Templates (Phase 8) ---
TEMPLATE_ENABLED=true
TEMPLATE_MAX_CONTEXT_SIZE=512000
TEMPLATE_TIMEOUT=60000
TEMPLATE_ALLOW_PROJECT_CONTEXT=false

# --- Admin (Phase 9) ---
ADMIN_ENABLED=true
ADMIN_AUDIT_ENABLED=true
ADMIN_AUDIT_RETENTION_DAYS=365
SUPERADMIN_INITIAL=628xxxxxxxxxx
ALLOWED_USERS=628xxxxxxxxxx
